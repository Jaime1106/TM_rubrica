generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  name      String?
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  assets    Asset[]
  maintenances Maintenance[]
}

model Asset {
  id          String        @id @default(cuid())
  name        String
  type        String
  brand       String?
  model       String?
  serial      String?       @unique
  purchaseDate DateTime?
  status      Status        @default(ACTIVE)
  location    String?
  userId      String?
  user        User?         @relation(fields: [userId], references: [id])
  maintenances Maintenance[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model Maintenance {
  id          String   @id @default(cuid())
  assetId     String
  asset       Asset    @relation(fields: [assetId], references: [id])
  date        DateTime @default(now())
  type        String
  description String
  cost        Float?
  technician  String?
  userId      String?
  user        User?    @relation(fields: [userId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

enum Status {
  ACTIVE
  IN_MAINTENANCE
  RETIRED
  LOST
}